{
  "name": "@precis/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test": "env/bin/pytest tests/ -v",
    "lint": "ruff check app/ tests/",
    "lint:fix": "ruff check --fix app/ tests/",
    "format": "ruff format app/ tests/",
    "format:check": "ruff format --check app/ tests/",
    "migrate": "env/bin/python -m scripts.migrate upgrade head",
    "migrate:generate": "env/bin/python -m scripts.migrate revision --autogenerate -m",
    "migrate:downgrade": "env/bin/python -m scripts.migrate downgrade -1",
    "migrate:history": "env/bin/python -m scripts.migrate history"
  }
}